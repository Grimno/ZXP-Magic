{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZXP Magic",
  "version": "1.2.0",
  "identifier": "com.egehan.zxp-magic",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ZXP Magic",
        "width": 920,
        "height": 620,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQjg2MTJENEQxNzQ4REMKUldUY1NCZE5MV0c0ZzdGbVNUbUNieVJEcXRBNnN4NXhtdFdtZjhkK3FnVzJERHlUMzVCVDhXM3kK",
      "endpoints": [
        "https://github.com/Grimno/ZXP-Magic/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Grimno",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false,
      "entitlements": null
    }
  }
}
